<?xml version="1.0" encoding="utf-8"?>
<!-- Cloud backup and device-to-device transfer for Android 12 and higher. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="npcs.db" />
        <include domain="file" path="portraits/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="npcs.db" />
        <include domain="file" path="portraits/" />
    </device-transfer>
</data-extraction-rules>

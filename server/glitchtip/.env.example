# Copy to .env (gitignored) or let deploy.sh generate it with fresh random values.
# Both are required; deploy.sh refuses to deploy without them.

# Django secret. Any long random string. Rotating it invalidates sessions (you re-login), nothing else.
SECRET_KEY=change_me

# Postgres password for the glitchtip role. CHANGING THIS AFTER THE FIRST DEPLOY DOES NOT
# re-create the role — the database keeps the original password, so the app can no longer connect.
# To rotate: ALTER USER glitchtip WITH PASSWORD '...' inside the postgres container, then update here.
POSTGRES_PASSWORD=change_me

# Optional: pin a different GlitchTip release (defaults to the tag in docker-compose.yml).
#GLITCHTIP_TAG=6.2.0
